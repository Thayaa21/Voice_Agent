# Copy this to .env and fill in your values
# .env is in .gitignore — never commit it

# ---- LLM Provider ----
# Options: ollama (local, free) | openai (cloud, paid)
LLM_PROVIDER=ollama

# ---- Ollama settings (when LLM_PROVIDER=ollama) ----
OLLAMA_MODEL=qwen2.5:14b-instruct-q4_K_M
OLLAMA_HOST=http://localhost:11434

# ---- OpenAI settings (when LLM_PROVIDER=openai) ----
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ---- UiPath Document Understanding API ----
# Get from: cloud.uipath.com → Admin → External Applications
# Scope needed: Du.DocumentProcessing.API
# UIPATH_CLIENT_ID=your_client_id_here
# UIPATH_CLIENT_SECRET=your_client_secret_here
# UIPATH_ORG=your_org_name_here   (e.g. qbotibzowkpm from cloud.uipath.com URL)
# UIPATH_TENANT=DefaultTenant     (found under Admin → Tenants)
